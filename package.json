{
  "name": "jacoballen-site",
  "type": "module",
  "version": "0.0.1",
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "fetch-blog": "rm -rf src/content/blog && git clone --depth 1 https://github.com/Jallen519/Jacob-Allen-Blog.git src/content/blog",
    "dev:full": "npm run fetch-blog && astro dev",
    "build:full": "npm run fetch-blog && astro build",
    "astro": "astro"
  },
  "dependencies": {
    "@astrojs/sitemap": "^3.7.0",
    "astro": "^5.17.1"
  },
  "devDependencies": {
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.2.1",
    "tailwindcss": "^4.2.1"
  }
}

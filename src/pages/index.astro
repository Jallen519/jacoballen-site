---
import BaseLayout from '../layouts/BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import NewsletterCTA from '../components/NewsletterCTA.astro';
import BlogCard from '../components/BlogCard.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog').catch(() => []);
const posts = allPosts
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const topics = [
  {
    title: 'Markets & Finance',
    description: 'Wealth building, macro trends, and what financial freedom actually requires.',
  },
  {
    title: 'Real Estate',
    description: 'Strategy, deals, creative financing, and building a portfolio from scratch.',
  },
  {
    title: 'AI & Automation',
    description: 'How technology is changing the game for investors and operators.',
  },
];
---

<BaseLayout title="Home">
  <Nav />
  <div class="max-w-3xl mx-auto px-6">
    <Hero />

    <section class="py-16 border-t border-(--color-rule)">
      <h2 class="font-serif text-2xl md:text-3xl font-semibold text-(--color-ink) mb-10 text-center">What I Write About</h2>
      <div class="grid md:grid-cols-3 gap-8">
        {topics.map(t => (
          <div class="text-center pt-6 border-t-2 border-(--color-accent)/30">
            <h3 class="font-serif text-lg font-semibold text-(--color-ink) mb-3">{t.title}</h3>
            <p class="text-sm text-(--color-ink-muted) leading-relaxed">{t.description}</p>
          </div>
        ))}
      </div>
    </section>

    {posts.length > 0 && (
      <section class="py-16 border-t border-(--color-rule)">
        <div class="flex items-center justify-between mb-10">
          <h2 class="font-serif text-2xl md:text-3xl font-semibold text-(--color-ink)">Latest Posts</h2>
          <a href="/blog" class="text-sm font-medium tracking-wide uppercase text-(--color-accent) hover:text-(--color-accent-dark) transition-colors">View all &rarr;</a>
        </div>
        <div class="space-y-0 divide-y divide-(--color-rule-light)">
          {posts.map(post => (
            <BlogCard
              title={post.data.title}
              date={post.data.date}
              category={post.data.category}
              slug={post.id}
            />
          ))}
        </div>
      </section>
    )}

    <div class="border-t border-(--color-rule)">
      <NewsletterCTA />
    </div>
  </div>
  <Footer />
</BaseLayout>

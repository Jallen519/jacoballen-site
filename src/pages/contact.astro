---
import PageLayout from '../layouts/PageLayout.astro';
import ContactForm from '../components/ContactForm.astro';
import { socials, email } from '../data/socials';
---

<PageLayout title="Contact" description="Get in touch with Jacob Allen.">
  <header class="mb-12 text-center">
    <h1 class="font-serif text-3xl md:text-4xl font-semibold text-(--color-ink) mb-4">Get in Touch</h1>
    <p class="text-(--color-ink-muted) max-w-xl mx-auto leading-relaxed">
      Have a question, opportunity, or just want to connect? Drop me a message and I'll get back to you.
    </p>
  </header>

  <div class="grid md:grid-cols-5 gap-12">
    <div class="md:col-span-3">
      <ContactForm />
    </div>
    <div class="md:col-span-2">
      <div class="border border-(--color-rule-light) p-6">
        <h3 class="text-sm font-semibold text-(--color-ink) mb-4 tracking-wide uppercase">Other Ways to Reach Me</h3>
        <div class="space-y-4">
          <div>
            <p class="text-xs text-(--color-ink-muted) mb-1">Email</p>
            <a href={`mailto:${email}`} class="text-sm text-(--color-accent) hover:text-(--color-accent-dark) transition-colors">{email}</a>
          </div>
          <div>
            <p class="text-xs text-(--color-ink-muted) mb-2">Socials</p>
            <div class="flex flex-col gap-2">
              {socials.map(s => (
                <a
                  href={s.url}
                  target="_blank"
                  rel="noopener noreferrer"
                  class="text-sm text-(--color-ink-light) hover:text-(--color-accent) transition-colors"
                >
                  {s.name} &rarr;
                </a>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</PageLayout>

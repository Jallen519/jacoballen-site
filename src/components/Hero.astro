---
const tagline = "Meditations on real estate, markets, and building wealth.";
---

<section class="py-20 md:py-28 text-center">
  <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-semibold text-(--color-ink) leading-tight mb-6 tracking-tight">
    Jacob Allen
  </h1>
  <p class="text-lg md:text-xl text-(--color-ink-muted) max-w-xl mx-auto leading-relaxed font-light">
    {tagline}
  </p>
  <div class="mt-10 flex justify-center gap-6">
    <a href="/about" class="text-sm font-medium tracking-wide uppercase text-(--color-accent) hover:text-(--color-accent-dark) transition-colors border-b border-(--color-accent) pb-0.5">
      About
    </a>
    <a href="/blog" class="text-sm font-medium tracking-wide uppercase text-(--color-accent) hover:text-(--color-accent-dark) transition-colors border-b border-(--color-accent) pb-0.5">
      Read the Blog
    </a>
  </div>
</section>

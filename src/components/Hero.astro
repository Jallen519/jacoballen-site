<section class="py-20 md:py-28 text-center">
  <div class="w-24 h-24 mx-auto mb-8 rounded-full bg-(--color-cream-dark) border border-(--color-rule) flex items-center justify-center overflow-hidden">
    <!-- Replace with: <img src="/images/headshot.jpg" alt="Jacob Allen" class="w-full h-full object-cover" /> -->
    <span class="font-serif text-2xl text-(--color-ink-muted)">JA</span>
  </div>
  <h1 class="font-serif text-4xl md:text-5xl lg:text-6xl font-semibold text-(--color-ink) leading-tight mb-6 tracking-tight">
    Jacob Allen
  </h1>
  <p class="text-lg md:text-xl text-(--color-ink-muted) max-w-xl mx-auto leading-relaxed font-light">
    Honest takes on real estate, markets, and building wealth.
  </p>
  <div class="mt-10 max-w-md mx-auto">
    <form
      data-subscribe-form
      action="/api/subscribe"
      method="POST"
      class="flex flex-col sm:flex-row gap-3"
    >
      <input
        type="email"
        name="email"
        required
        placeholder="Your email address"
        class="grow px-4 py-3 text-sm bg-(--color-cream-dark) border border-(--color-rule) text-(--color-ink) placeholder-(--color-ink-muted) focus:outline-none focus:border-(--color-accent) focus:ring-1 focus:ring-(--color-accent) transition-colors"
      />
      <button
        type="submit"
        class="px-6 py-3 text-sm font-semibold tracking-wide uppercase bg-(--color-ink) text-(--color-cream) hover:bg-(--color-ink-light) transition-colors whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p data-subscribe-success class="hidden text-sm text-(--color-accent) mt-4 font-medium">
      You're in. Thanks for subscribing.
    </p>
    <p data-subscribe-error class="hidden text-sm text-red-600 mt-4">
      Something went wrong. Please try again.
    </p>
  </div>
  <div class="mt-6">
    <a href="/blog" class="text-sm text-(--color-ink-muted) hover:text-(--color-accent) transition-colors">
      or read the blog &rarr;
    </a>
  </div>
</section>

<script>
  document.querySelectorAll('[data-subscribe-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const formData = new FormData(formEl);
      const container = formEl.closest('section') || formEl.parentElement;
      const successEl = container?.querySelector('[data-subscribe-success]');
      const errorEl = container?.querySelector('[data-subscribe-error]');

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          body: formData,
        });

        if (res.ok) {
          formEl.classList.add('hidden');
          successEl?.classList.remove('hidden');
          errorEl?.classList.add('hidden');
        } else {
          const data = await res.json();
          if (errorEl) {
            errorEl.textContent = data.error || 'Something went wrong. Please try again.';
            errorEl.classList.remove('hidden');
          }
        }
      } catch {
        errorEl?.classList.remove('hidden');
      }
    });
  });
</script>

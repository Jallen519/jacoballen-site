---
import { formatDate } from '../lib/formatters';

interface Props {
  title: string;
  date: Date;
  category: string;
  slug: string;
  excerpt?: string;
}

const { title, date, category, slug, excerpt } = Astro.props;
---

<a href={`/blog/${slug}`} class="group block py-6 first:pt-0 last:pb-0">
  <div class="flex items-center gap-3 mb-2">
    <span class="text-xs font-medium tracking-wide uppercase text-(--color-accent)">
      {category}
    </span>
    <span class="text-(--color-rule)">&middot;</span>
    <time class="text-xs text-(--color-ink-muted)" datetime={date.toISOString()}>
      {formatDate(date)}
    </time>
  </div>
  <h3 class="font-serif text-xl font-semibold text-(--color-ink) group-hover:text-(--color-accent) transition-colors mb-1">
    {title}
  </h3>
  {excerpt && (
    <p class="text-sm text-(--color-ink-muted) line-clamp-2 leading-relaxed">
      {excerpt}
    </p>
  )}
</a>

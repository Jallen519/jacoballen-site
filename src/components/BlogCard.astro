---
import { formatDate } from '../lib/formatters';

interface Props {
  title: string;
  date: Date;
  category: string;
  slug: string;
  excerpt?: string;
}

const { title, date, category, slug, excerpt } = Astro.props;
---

<a href={`/blog/${slug}`} class="group block bg-zinc-900 border border-zinc-800 rounded-xl p-6 hover:border-zinc-700 transition-colors">
  <div class="flex items-center gap-3 mb-3">
    <span class="text-xs font-medium px-2 py-0.5 rounded-full bg-amber-400/10 text-amber-400 border border-amber-400/20">
      {category}
    </span>
    <time class="text-xs text-zinc-500" datetime={date.toISOString()}>
      {formatDate(date)}
    </time>
  </div>
  <h3 class="text-lg font-semibold text-zinc-50 group-hover:text-amber-400 transition-colors mb-2">
    {title}
  </h3>
  {excerpt && (
    <p class="text-sm text-zinc-400 line-clamp-2">
      {excerpt}
    </p>
  )}
</a>

---
interface Props {
  heading?: string;
  subtext?: string;
  compact?: boolean;
}

const {
  heading = "Follow Along",
  subtext = "I write about real estate, markets, and what I'm learning as I build. No fluff — just honest takes.",
  compact = false,
} = Astro.props;
---

<section class:list={[
  "text-center",
  compact ? "py-12" : "py-16 md:py-20",
]}>
  <div class="max-w-lg mx-auto">
    <h2 class:list={[
      "font-serif font-semibold text-(--color-ink) mb-4",
      compact ? "text-2xl" : "text-2xl md:text-3xl",
    ]}>
      {heading}
    </h2>
    <p class="text-(--color-ink-muted) mb-8 leading-relaxed">
      {subtext}
    </p>
    <a
      href="/blog"
      class="inline-block px-8 py-3 text-sm font-semibold tracking-wide uppercase bg-(--color-ink) text-(--color-cream) hover:bg-(--color-ink-light) transition-colors"
    >
      Read the Blog
    </a>
  </div>
</section>

---
interface Props {
  heading?: string;
  subtext?: string;
  compact?: boolean;
}

const {
  heading = "Join the Newsletter",
  subtext = "One email a week. No spam, no pitches \u2014 just what I'm learning about real estate, markets, and building wealth.",
  compact = false,
} = Astro.props;
---

<section class:list={[
  "text-center",
  compact ? "py-12" : "py-16 md:py-20",
]}>
  <div class="max-w-lg mx-auto">
    <h2 class:list={[
      "font-serif font-semibold text-(--color-ink) mb-3",
      compact ? "text-2xl" : "text-2xl md:text-3xl",
    ]}>
      {heading}
    </h2>
    <p class="text-(--color-ink-muted) mb-8 leading-relaxed">
      {subtext}
    </p>
    <form
      data-subscribe-form
      action="/api/subscribe"
      method="POST"
      class="flex flex-col sm:flex-row gap-3 max-w-md mx-auto"
    >
      <input
        type="email"
        name="email"
        required
        placeholder="Your email address"
        class="grow px-4 py-3 text-sm bg-(--color-cream-dark) border border-(--color-rule) text-(--color-ink) placeholder-(--color-ink-muted) focus:outline-none focus:border-(--color-accent) focus:ring-1 focus:ring-(--color-accent) transition-colors"
      />
      <button
        type="submit"
        class="px-6 py-3 text-sm font-semibold tracking-wide uppercase bg-(--color-ink) text-(--color-cream) hover:bg-(--color-ink-light) transition-colors whitespace-nowrap"
      >
        Subscribe
      </button>
    </form>
    <p data-subscribe-success class="hidden text-sm text-(--color-accent) mt-4 font-medium">
      You're in. Thanks for subscribing.
    </p>
    <p data-subscribe-error class="hidden text-sm text-red-600 mt-4">
      Something went wrong. Please try again.
    </p>
  </div>
</section>

<script>
  document.querySelectorAll('[data-subscribe-form]').forEach((form) => {
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      const formEl = e.target as HTMLFormElement;
      const formData = new FormData(formEl);
      const container = formEl.closest('section');
      const successEl = container?.querySelector('[data-subscribe-success]');
      const errorEl = container?.querySelector('[data-subscribe-error]');

      try {
        const res = await fetch('/api/subscribe', {
          method: 'POST',
          body: formData,
        });

        if (res.ok) {
          formEl.classList.add('hidden');
          successEl?.classList.remove('hidden');
          errorEl?.classList.add('hidden');
        } else {
          const data = await res.json();
          if (errorEl) {
            errorEl.textContent = data.error || 'Something went wrong. Please try again.';
            errorEl.classList.remove('hidden');
          }
        }
      } catch {
        errorEl?.classList.remove('hidden');
      }
    });
  });
</script>

---
const pathname = Astro.url.pathname;

const links = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/contact', label: 'Contact' },
];

function isActive(href: string): boolean {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
}
---

<nav class="border-b border-zinc-800 bg-zinc-950/80 backdrop-blur-md sticky top-0 z-50">
  <div class="max-w-5xl mx-auto px-6 flex items-center justify-between h-16">
    <a href="/" class="text-lg font-semibold text-zinc-50 hover:text-amber-400 transition-colors">
      Jacob Allen
    </a>
    <div class="hidden md:flex items-center gap-8">
      {links.map(link => (
        <a
          href={link.href}
          class:list={[
            'text-sm transition-colors',
            isActive(link.href)
              ? 'text-amber-400 font-medium'
              : 'text-zinc-400 hover:text-zinc-50',
          ]}
        >
          {link.label}
        </a>
      ))}
    </div>
    <button
      id="mobile-menu-toggle"
      class="md:hidden text-zinc-400 hover:text-zinc-50"
      aria-label="Toggle menu"
    >
      <svg xmlns="http://www.w3.org/2000/svg" class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16" />
      </svg>
    </button>
  </div>
  <div id="mobile-menu" class="md:hidden hidden border-t border-zinc-800 bg-zinc-950 px-6 pb-4">
    {links.map(link => (
      <a
        href={link.href}
        class:list={[
          'block py-3 text-sm transition-colors',
          isActive(link.href)
            ? 'text-amber-400 font-medium'
            : 'text-zinc-400 hover:text-zinc-50',
        ]}
      >
        {link.label}
      </a>
    ))}
  </div>
</nav>

<script>
  const toggle = document.getElementById('mobile-menu-toggle');
  const menu = document.getElementById('mobile-menu');
  toggle?.addEventListener('click', () => menu?.classList.toggle('hidden'));
</script>

---
import BaseLayout from './BaseLayout.astro';
import Nav from '../components/Nav.astro';
import Footer from '../components/Footer.astro';
import { formatDate } from '../lib/formatters';

interface Props {
  title: string;
  date: Date;
  category: string;
  tags: string[];
}

const { title, date, category, tags } = Astro.props;
---

<BaseLayout title={title} description={`${title} — Jacob Allen's blog`}>
  <Nav />
  <main class="max-w-3xl mx-auto px-6 py-16">
    <article>
      <header class="mb-12">
        <div class="flex items-center gap-3 mb-4">
          <span class="text-xs font-medium px-2.5 py-1 rounded-full bg-amber-400/10 text-amber-400 border border-amber-400/20">
            {category}
          </span>
          <time class="text-sm text-zinc-500" datetime={date.toISOString()}>
            {formatDate(date)}
          </time>
        </div>
        <h1 class="text-3xl md:text-4xl font-bold text-zinc-50 leading-tight">
          {title}
        </h1>
        {tags.length > 0 && (
          <div class="flex flex-wrap gap-2 mt-4">
            {tags.map(tag => (
              <span class="text-xs text-zinc-500 px-2 py-0.5 rounded bg-zinc-800">
                {tag}
              </span>
            ))}
          </div>
        )}
      </header>
      <div class="prose prose-invert prose-zinc max-w-none prose-headings:text-zinc-50 prose-a:text-amber-400 prose-a:no-underline hover:prose-a:underline prose-code:text-amber-300 prose-pre:bg-zinc-900 prose-pre:border prose-pre:border-zinc-800">
        <slot />
      </div>
    </article>
    <div class="mt-16 pt-8 border-t border-zinc-800">
      <a href="/blog" class="text-sm text-amber-400 hover:underline">&larr; Back to all posts</a>
    </div>
  </main>
  <Footer />
</BaseLayout>
